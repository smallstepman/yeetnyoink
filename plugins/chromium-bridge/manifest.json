{
  "manifest_version": 3,
  "name": "Yeet and Yoink Chromium Bridge",
  "version": "0.1.0",
  "description": "Expose Chromium-family tab control to yeet-and-yoink via native messaging.",
  "permissions": [
    "nativeMessaging",
    "tabs",
    "alarms"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "minimum_chrome_version": "109",
  "key": ""
}
